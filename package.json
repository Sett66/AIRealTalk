{
  "name": "airealtalk",
  "private": true,
  "version": "0.1.0",
  "description": "AIRealTalk - English speaking practice monorepo",
  "scripts": {
    "postinstall": "node scripts/link-mobile-deps.js",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "dev:backend": "pnpm --filter @airealtalk/backend start:dev",
    "dev:mobile": "pnpm --filter @airealtalk/mobile start",
    "android": "pnpm --filter @airealtalk/mobile android"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.3"
}
